# Backend configuration for Jarvis AI assistant
CLIENT_ORIGIN=http://localhost:5173
PORT=5000

# Use Groq Cloud, OpenAI, or Gemini key for the chat API.
# GROQ_API_KEY is supported and will be used first if set.
# Example: GROQ_API_KEY=gsk_...
GROQ_API_KEY=sk_deWRAI1SVna9D8JcGejPWGdyb3FYG0KaFuBLWDmIlegHluO3codt

# Use a Groq model accessible to your key.
# Example: GROQ_MODEL=openai/gpt-oss-safeguard-20b
GROQ_MODEL=openai/gpt-oss-safeguard-20b

# Example: OPENAI_API_KEY=your_openai_api_key
OPENAI_API_KEY=

# If you prefer Google Gemini instead of OpenAI, set this key.
# Example: GEMINI_API_KEY=AIza...
GEMINI_API_KEY=
